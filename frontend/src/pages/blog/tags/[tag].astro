---
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/foundations/elements/Text.astro";
import Button from "@/components/foundations/elements/Button.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
// Component
import BlogSearch from "@/components/blog/BlogSearch.astro";
import BlogEntries2 from "@/components/blog/BlogEntries2.astro";
// Data
import { fetchAllBlogPosts, fetchAllBlogTags } from "@/data/sanity/fetch";
import { normalizeTag } from "@/utils/tags";

export async function getStaticPaths() {
  const tags = await fetchAllBlogTags();
  const slugs = [...new Set(tags.map((tag) => normalizeTag(tag)).filter(Boolean))];

  return slugs.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const normalizedTag = String(tag || "");
const allPosts = await fetchAllBlogPosts();
const posts = allPosts.filter((post) =>
  (post.tags || []).some((item) => normalizeTag(item) === normalizedTag)
);
const displayTag =
  posts.find((post) => (post.tags || []).some((item) => normalizeTag(item) === normalizedTag))?.tags?.find(
    (item) => normalizeTag(item) === normalizedTag
  ) || normalizedTag;
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <div class="grid items-end grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <Text
            tag="h1"
            variant="display2XL"
            data-aos="fade-up"
            data-aos-duration="1000"
            class="font-semibold tracking-tighter brand-heading-color lg:text-balance capitalize"
          >
            {displayTag}
          </Text>
          <Text
            tag="p"
            variant="textLG"
            data-aos="fade-up"
            data-aos-duration="1500"
            class="max-w-lg mt-4 font-medium brand-text-color md:text-balance"
          >
            Filtered posts for this topic.
          </Text>
        </div>
        <form data-aos="fade-up" data-aos-duration="2000">
          <label for="email" class="text-xs font-medium brand-text-color">
            Subscribe to our newsletter
          </label>
          <div class="flex flex-col gap-2 mt-1">
            <input
              type="email"
              id="email"
              placeholder="email@example.com"
              required
              class="block w-full h-10 px-4 py-2 text-sm text-teal-700 duration-300 border border-transparent rounded-lg appearance-none bg-base-100 placeholder-base-400 focus:bg-base-100 focus:outline-none focus:ring-teal-500 focus:ring-offset-2 focus:ring-2 focus:ring-offset-base-200"
            />
            <Button size="base" variant="default" type="submit" class="w-full">
              Subscribe
            </Button>
          </div>
          <Text tag="p" variant="textXS" class="mt-2 font-medium brand-text-color">
            By subscribing, you agree to receive our latest updates. No spam, promise!
          </Text>
        </form>
      </div>
    </Wrapper>
    <Wrapper variant="standard" class="py-4 border-t brand-border-color">
      <div>
        <BlogSearch posts={allPosts} />
      </div>
    </Wrapper>
    <Wrapper variant="standard" class="py-4 border-t brand-border-color">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 gap-y-12 lg:gap-y-24">
        {posts.map((post) => <BlogEntries2 post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
