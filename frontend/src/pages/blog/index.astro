---
// Foundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
// Components
import BlogEntries2 from "@/components/blog/BlogEntries2.astro";
// Data
import { fetchAllBlogPosts } from "@/data/sanity/fetch";
import { uniqueTagOptions } from "@/utils/tags";

const allPosts = await fetchAllBlogPosts();
const tags = uniqueTagOptions(allPosts.flatMap((post) => post.tags || []));
