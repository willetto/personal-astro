---
import { normalizeTag } from "@/utils/tags";

const { title } = Astro.props;
const slug = normalizeTag(String(title || ""));
---

<a
  class="TagLink text-sm font-medium brand-text-color hover:brand-heading-color"
  title={String(title || "")}
  aria-label={String(title || "")}
  href={`/blog/tags/${slug}`}
>{title}</a>
