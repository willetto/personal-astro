---
import { PortableText as PT } from "astro-portabletext";
import PortableCode from "./PortableCode.astro";
import PortableYouTube from "./PortableYouTube.astro";

interface Props {
  value?: any[];
}

const { value = [] } = Astro.props as Props;
---

<PT
  value={value}
  components={{
    type: {
      code: PortableCode,
      youtube: PortableYouTube,
    },
  }}
/>


